# Monorepo-wide ignores. Per-project .gitignore files still apply within each subfolder.

**/__pycache__/
**/*.pyc

# Blog cluster: translations live in *-full.json, not override modules
ggcms/sites/chickenroad/tools/chickenroad_blog_*_overrides*.py

# Deploy secrets — optional local overrides (deploy.ftp.local is tracked in private repo)
**/deploy.ftp.local.sftp-key

# Cloudflare API token (see ggcms/docs/CLOUDFLARE_ACCESS.md.example)
ggcms/docs/CLOUDFLARE_ACCESS.local.md

# Python
**/__pycache__/
**/.venv/
**/venv/
**/*.pyc

# Node
**/node_modules/

# Local scratch / export staging (not canonical reference JSON)
ggcms/sites/**/tmp/

# OS / editor
.DS_Store
*.swp
